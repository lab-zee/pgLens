{
  "name": "pglens",
  "version": "0.2.1",
  "private": true,
  "description": "Connect to PostgreSQL or SQLite and instantly visualize your database — tables, schemas, relationships, and data.",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:server": "pnpm --filter @pglens/server run dev",
    "dev:client": "pnpm --filter @pglens/client run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "start": "pnpm build && node packages/server/dist/index.js"
  },
  "keywords": [
    "postgres",
    "sqlite",
    "database",
    "visualization",
    "schema",
    "pglens"
  ],
  "license": "MIT",
  "author": "davidinwald",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidinwald/pglens"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
